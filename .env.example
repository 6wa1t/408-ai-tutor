# ============================================================
# 408考研AI专属助教 — 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置:  cp .env.example .env
#
# 本项目使用双模型架构:
#   - 推理模型 (必配): DeepSeek，用于 AI 助教对话和答题分析
#   - 视觉模型 (可选): 通义千问VL，用于扫描PDF识别和图片OCR
#   如果只使用文字型 PDF，可以不配置视觉模型
# ============================================================

# ===== 推理模型 (必配) =====
# API 基础地址 (DeepSeek 官方: https://api.deepseek.com)
# 也支持其他 OpenAI 兼容接口 (如本地 Ollama: http://localhost:11434/v1)
LLM_API_BASE=https://api.deepseek.com

# API 密钥
# DeepSeek: 访问 https://platform.deepseek.com/api_keys 创建
# 其他平台: 填入对应的 API Key
LLM_API_KEY=sk-your-api-key-here

# 模型名称 (DeepSeek: deepseek-chat / deepseek-reasoner)
LLM_MODEL=deepseek-chat

# ===== 视觉模型 (可选，扫描PDF需要) =====
# DeepSeek 不支持图片输入，扫描版 PDF 的题目提取需要单独的视觉模型。
# 默认配置: 通义千问VL (阿里云百炼平台, OpenAI兼容API)
# API Key 申请地址: https://bailian.console.aliyun.com/
# 新用户有免费额度，qwen-vl-max 效果最好，qwen-vl-plus 更便宜
# 如果只用文字型 PDF，此项可留空

# 视觉模型 API 地址 (通义千问VL默认值，一般不需要改)
VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 视觉模型 API Key (阿里云百炼平台)
VISION_API_KEY=sk-your-dashscope-api-key-here

# 视觉模型名称 (qwen-vl-max / qwen-vl-plus / qwen-vl-max-latest)
VISION_MODEL=qwen-vl-max

# --- 应用配置 ---
# 调试模式 (true=自动创建数据库表 + 允许所有跨域请求, 首次运行请设为true)
DEBUG=true

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
